venv/

# ===== 包运行时生成态（关键：防止把本机状态/锁带出去）=====
# 注意：packages/installed/ 不整体忽略——index.toml 引用其中的 package.toml 作为
# current_source（装配索引 + 集成测试发现所必需）。仅忽略 wasm 产物与运行时态：
packages/installed/**/active
packages/installed/**/previous
packages/installed/**/lock.toml
packages/installed/**/generation-store.toml
packages/installed/**/generations/
packages/installed/**/Cargo.lock
packages/*/active
packages/*/previous
packages/*/lock.toml
packages/*/generation-store.toml
packages/*/generations/
packages/official/*/data/
packages/official/*/runtime-debug/
**/*.wasm
**/*.bak
**/*.bak-*

# ===== 本地配置 / 密钥（只保留 config.example.toml）=====
config.toml
config.dev.toml
config/config.toml
config/config.dev.toml
.env
*.key
*.pem
*.p12

